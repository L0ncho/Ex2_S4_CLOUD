# Perfil activo: local (H2) | prod (Oracle)
SPRING_PROFILES_ACTIVE=local

# Solo perfil prod — Oracle Cloud Autonomous (mTLS vía wallet)
# run-prod.sh exporta TNS_ADMIN=./Wallet_ENROLLMENTPLATFORMDB
# Alias disponibles en tnsnames.ora: enrollmentplatformdb_high | _medium | _low
SPRING_DATASOURCE_URL=jdbc:oracle:thin:@enrollmentplatformdb_high
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Opcional: ruta absoluta si la wallet no está en Wallet_ENROLLMENTPLATFORMDB
# ORACLE_WALLET_DIR=/ruta/a/Wallet_ENROLLMENTPLATFORMDB

SERVER_PORT=8080
